{
  "name": "terrarium-mcp",
  "version": "1.1.0",
  "description": "MCP terrarium: environment, context, and dependencies for open-source PBX module development",
  "author": "James Finstrom",
  "type": "module",
  "bin": {
    "terrarium-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http",
    "test": "npm run build && node --import tsx --test test/integration/stdio-server.test.ts test/integration/http-server.test.ts",
    "test:integration": "npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "freepbx",
    "mcp",
    "model-context-protocol",
    "asterisk",
    "module-development"
  ],
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}